# nom-nom — environment. Copy to .env and fill in.

# auth-center (see CLAUDE.md)
AUTH_URL=https://auth-center.sh-development.ru
AUTH_INTERNAL=https://auth-center.sh-development.ru
APP_URL=http://localhost:8890
APP_TOKEN=
SECRET_KEY=dev-secret

# app — DB_PATH points at the /data named volume (dev-compose), NOT the bind mount:
# modernc sqlite locking fails on macOS virtiofs. In prod use an absolute disk path.
DB_PATH=/data/nom-nom.db
PORT=8890

# Claude scan — model is NOT hardcoded so you can A/B test; default is Sonnet.
ANTHROPIC_API_KEY=
SCAN_MODEL=claude-opus-4-8
