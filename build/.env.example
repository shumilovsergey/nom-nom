# nom-nom — environment. Copy to .env and fill in.

# auth-center (see CLAUDE.md)
AUTH_URL=https://auth-center.sh-development.ru
AUTH_INTERNAL=https://auth-center.sh-development.ru
APP_URL=http://localhost:8890
APP_TOKEN=
SECRET_KEY=dev-secret

# app — DB_PATH points at the /data named volume (dev-compose), NOT the bind mount:
# modernc sqlite locking fails on macOS virtiofs. In prod use an absolute disk path.
DB_PATH=/data/nom-nom.db
PORT=8890

# Claude scan — requests go through our proxy-project, which holds the real
# Anthropic key. nom-nom authenticates to the proxy with the shared NOM_NOM_SECRET,
# sent as `Authorization: Bearer <secret>`. ANTHROPIC_API_KEY lives only on the proxy.
AI_PROXY_URL=https://auth-proxy.sh-development.ru/nom-nom-ai
AI_PROXY_SECRET=
# model is NOT hardcoded so you can A/B test without a rebuild.
SCAN_MODEL=claude-opus-4-8

# lifetime free AI scans a NEW user starts with. Changing this affects only users
# who sign up afterwards — existing users keep whatever they have left.
FREE_SCANS=3
